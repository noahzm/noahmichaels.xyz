---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import influence from "../images/influence.jpg";
import spread from "../images/influence/spread1.jpg";
---

<Layout
  title="Influence – Noah Michaels"
  description="A small photo book about films that have inspired me. School project by Noah Michaels."
>
  <div class="md:p-4 px-4 pb-8 md:max-w-7/10 mr-auto">
    <div class="flex flex-col md:flex-row gap-4">
      <div class="md:basis-3/7">
        <Picture
          src={influence}
          alt="Influence cover"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
      </div>
      <div class="md:basis-4/7 flex flex-col justify-between">
        <div>
          <h1
            class="text-4xl font-sans font-extralight mb-2 flex justify-between w-full"
          >
            Influence
          </h1>
          <p class="pb-4">
            <span class="text-red-500 text-sm border rounded-full px-2"
              >Print</span
            >
            <span class="text-sm border rounded-full px-2">2019</span>
          </p>
          <p class="mb-4">
            <span class="block"
              >Influence is a small coffee table book featuring stills from
              films that have inspired me as a visual artist and storyteller.
              Each spread pairs a film still with a personal reflection,
              exploring how each work has shaped my creative perspective.</span
            >
          </p>
          <ul class="list-disc pl-5 mb-4">
            <li>Role: Curator, Designer, Writer</li>
            <li>Medium: Print (coffee table book)</li>
            <li>School Project</li>
          </ul>
          <p class="mb-4">
            Focus Areas: Editorial design, photography curation, and personal
            narrative through visual storytelling.
          </p>
        </div>
      </div>
    </div>

    <div class="my-8 border-b"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <Picture
          src={spread}
          alt="Influence spread"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
        <p class="text-sm">Sample spread showing film still and reflection</p>
      </div>
    </div>
  </div>
</Layout>
