---
import Nav from "../components/Nav.astro";
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import ncga from "../images/ncga.jpg";
import { MegaphoneSimpleIcon } from "@phosphor-icons/react";
---

<Nav />
<Layout>
  <div class="md:p-4 px-4 pb-4 md:max-w-7/10">
    <div class="flex flex-col md:flex-row">
      <div class="md:basis-3/7 md:py-0 py-4 md:pr-4">
        <Picture
          src={ncga}
          alt="North Carolina General Assembly"
          class="aspect-4/3 object-cover"
          loading="eager"
        />
      </div>
      <div class="md:basis-3/7 md:pr-4">
        <p class="[&:not(:first-child)]:mt-4 text-2xl font-sans">North Carolina General Assembly</p>
        <p class="mt-4">
          Designed promotional materials for the North Carolina General Assembly, supporting their career fairs at colleges and universities across the state. Materials included posters, flyers, and digital graphics to engage students and promote public service careers.
        </p>
      </div>
      <div class="md:basis-1/7">
        <p class="[&:not(:first-child)]:mt-4 mt-4 md:mt-0 uppercase font-sans">2025</p>
        <MegaphoneSimpleIcon size={32} weight="fill" />
      </div>
    </div>
  </div>
</Layout>
