---
import Nav from "../components/Nav.astro";
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import boro from "../images/boro.png";
import { DiscIcon } from "@phosphor-icons/react";
---

<Nav />
<Layout>
  <div class="md:p-4 px-4 pb-4 md:max-w-7/10">
    <div class="flex flex-col md:flex-row">
      <div class="md:basis-3/7 md:py-0 py-4 md:pr-4">
        <Picture
          src={boro}
          alt="Boro"
          class="aspect-4/3 object-cover"
          loading="eager"
        />
      </div>
      <div class="md:basis-3/7 md:pr-4">
        <p class="[&:not(:first-child)]:mt-4 text-2xl font-sans">Boro</p>
        <p class="mt-4">
          Designed merchandise and album artwork for Boro, a rap group based in Greensboro, NC. Work supported their visual identity and helped promote their music and brand. Projects included t-shirt designs, album covers, and event flyers.
        </p>
      </div>
      <div class="md:basis-1/7">
        <p class="[&:not(:first-child)]:mt-4 mt-4 md:mt-0 uppercase font-sans">2023</p>
        <DiscIcon size={32} weight="fill" />
      </div>
    </div>
  </div>
</Layout>
