---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import grouch from "../images/grouch.jpg";
import stickers from "../images/grouch/stickers.jpg";
import press from "../images/grouch/press.jpg";
import hat from "../images/grouch/hat.jpg";
import model from "../images/grouch/model.jpg";
---

<Layout
  title="Grouch – Noah Michaels"
  description="A screen printing clothing project by Noah Michaels."
>
  <div class="md:p-4 px-4 pb-8 md:max-w-7/10 mr-auto">
    <div class="flex flex-col md:flex-row gap-4">
      <div class="md:basis-3/7">
        <Picture
          src={grouch}
          alt="Grouch t-shirt"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
      </div>
      <div class="md:basis-4/7 flex flex-col justify-between">
        <div>
          <h1
            class="text-4xl font-sans font-extralight mb-2 flex justify-between w-full"
          >
            Grouch
          </h1>
          <p class="pb-4">
            <span class="text-blue-500 text-sm border rounded-full px-2"
              >Apparel</span
            >
            <span class="text-sm border rounded-full px-2">2022</span>
          </p>
          <p class="mb-4">
            <span class="block"
              >Grouch was a project focused on designing and screen printing a
              small run of t-shirts. The project involved creating original
              graphics, preparing screens, and printing each shirt by hand in a
              studio setting.</span
            >
          </p>
          <ul class="list-disc pl-5 mb-4">
            <li>Role: Designer, Screen Printer</li>
            <li>
              Medium: Apparel (screen printed t-shirts, embroidered hats) and
              stickers
            </li>
            <li>Personal Project</li>
          </ul>
          <p class="mb-4">
            Focus Areas: Screen printing production, graphic design for apparel,
            and small-batch manufacturing processes.
          </p>
        </div>
      </div>
    </div>

    <div class="my-8 border-b"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <Picture
          src={stickers}
          alt="Grouch stickers"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
        <p class="text-sm">Branded stickers</p>
      </div>

      <div class="space-y-4">
        <Picture
          src={press}
          alt="Screen printing press"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
        <p class="text-sm">Screen printing process and production</p>
      </div>

      <div class="space-y-4">
        <Picture
          src={hat}
          alt="Grouch hat"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
        <p class="text-sm">Embroidered hat design</p>
      </div>

      <div class="space-y-4">
        <Picture
          src={model}
          alt="Grouch on model"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
        <p class="text-sm">Final product photography</p>
      </div>
    </div>
  </div>
</Layout>
