---
// Core layout components
import Layout from "../layouts/Layout.astro";

// UI components
import { Picture } from "astro:assets";

// Assets
import phasezero from "../images/phase-zero.webp";
---

<Layout
  title="Phase Zero – Noah Michaels"
  description="Submission to Phase Zero Issue 9, a print publication archiving creative culture. Digital illustration by Noah Michaels."
>
  <div class="md:p-4 px-4 pb-8 md:max-w-7/10 mr-auto">
    <div class="flex flex-col md:flex-row gap-4">
      <div class="md:basis-3/7">
        <Picture
          src={phasezero}
          alt="Phase Zero publication cover"
          class="aspect-[4/3] object-cover border border-black"
          loading="eager"
          width="800"
          height="600"
          layout="constrained"
        />
      </div>
      <div class="md:basis-4/7 flex flex-col justify-between">
        <div>
          <h1
            class="text-4xl font-sans font-extralight mb-2 flex justify-between w-full"
          >
            Phase Zero
          </h1>
          <p class="pb-4">
            <span class="text-red-500 text-sm border rounded-full px-2"
              >Print</span
            >
            <span class="text-sm border rounded-full px-2">2025</span>
          </p>
          <p class="mb-4">
            <span class="block mb-4"
              >Digital artwork accepted for publication in Issue 9 of <span
                class="italic">Phase Zero</span
              >, a curated print publication based in New York City that
              archives contemporary creative culture. The issue brings together
              works from various artists, including illustration, photography,
              poetry, and creative writing.</span
            >
          </p>
          <ul class="list-disc pl-5 mb-4">
            <li>Role: Contributing Artist</li>
            <li>Medium: Digital Illustration</li>
            <li>Publication: Phase Zero Issue 9</li>
          </ul>
          <p class="mb-4">
            Focus Areas: Digital art creation, publication submission process,
            and participation in NYC's creative community.
          </p>
        </div>
        <div class="mt-6">
          <a
            href="https://phasezeronyc.com/zines"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-5 py-2 border text-black transition-colors hover:bg-black hover:text-white"
            >View Publication</a
          >
        </div>
      </div>
    </div>
  </div>
</Layout>
