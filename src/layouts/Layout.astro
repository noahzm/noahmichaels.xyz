---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
const {
  title = "Noah Michaels – Portfolio",
  description = "Portfolio of Noah Michaels – designer, developer, and creative based in Raleigh, NC.",
} = Astro.props;
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Noah M" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body class="bg-background min-h-screen">
    <slot />
  </body>
</html>
